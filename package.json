{
  "name": "xlsx-diff",
  "publisher": "codetypess",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "icon": "media/icon.png",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/codetypess/vscode-xlsx-diff#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/codetypess/vscode-xlsx-diff.git"
  },
  "bugs": {
    "url": "https://github.com/codetypess/vscode-xlsx-diff/issues"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "xlsx",
    "excel",
    "spreadsheet",
    "diff",
    "compare",
    "git",
    "svn",
    "subversion",
    "scm"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "xlsx-difftool": "./scripts/xlsx-difftool.mjs",
    "xlsx-svn-diffwrap": "./scripts/xlsx-svn-diffwrap.mjs"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "XLSX Diff reads workbook contents and can write local workbook files when cell editing is used."
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "XLSX Diff currently requires local file-system access to compare and edit workbook files."
    }
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "xlsx-diff.editorPanel",
        "displayName": "%customEditor.xlsx.displayName%",
        "selector": [
          {
            "filenamePattern": "*.xlsx"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "xlsx-diff.compareTwoFiles",
        "title": "%command.compareTwoFiles.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlsx-diff.openEditor",
        "title": "%command.openEditor.title%",
        "shortTitle": "%command.openEditor.shortTitle%",
        "category": "%command.category%"
      },
      {
        "command": "xlsx-diff.compareActiveWith",
        "title": "%command.compareActiveWith.title%",
        "shortTitle": "%command.compareActiveWith.shortTitle%",
        "category": "%command.category%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "xlsx-diff.openEditor",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        },
        {
          "command": "xlsx-diff.compareActiveWith",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        },
        {
          "command": "xlsx-diff.compareTwoFiles",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        }
      ],
      "editor/context": [
        {
          "command": "xlsx-diff.openEditor",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        },
        {
          "command": "xlsx-diff.compareActiveWith",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "xlsx-diff.compareActiveWith",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "xlsx-diff.displayLanguage": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh-CN"
          ],
          "default": "auto",
          "markdownDescription": "%configuration.displayLanguage.description%",
          "enumDescriptions": [
            "%configuration.displayLanguage.auto%",
            "%configuration.displayLanguage.en%",
            "%configuration.displayLanguage.zhCn%"
          ]
        }
      }
    }
  },
  "scripts": {
    "format": "prettier --write media scripts src",
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node --import tsx scripts/esbuild.mts",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node --import tsx scripts/esbuild.mts --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "watch:tsc-webview": "tsc --noEmit --watch --project tsconfig.webview.json",
    "package": "npm run check-types && npm run lint && node --import tsx scripts/esbuild.mts --production",
    "compile-tests": "node -e \"require('fs').rmSync('out', { recursive: true, force: true })\" && node --import tsx scripts/esbuild-tests.mts",
    "watch-tests": "node --import tsx scripts/esbuild-tests.mts --watch",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "npm-run-all check-types:*",
    "check-types:src": "tsc --noEmit -p tsconfig.json",
    "check-types:webview": "tsc --noEmit -p tsconfig.webview.json",
    "check-types:tools": "tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint src scripts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "1.105.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "fastxlsx": "^1.3.3"
  }
}
