{
  "name": "xlsx-diff",
  "publisher": "codetypess",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "xlsx-difftool": "./scripts/xlsx-difftool.mjs"
  },
  "contributes": {
    "commands": [
      {
        "command": "xlsx-diff.compareTwoFiles",
        "title": "%command.compareTwoFiles.title%",
        "category": "%command.category%"
      },
      {
        "command": "xlsx-diff.compareActiveWith",
        "title": "%command.compareActiveWith.title%",
        "shortTitle": "%command.compareActiveWith.shortTitle%",
        "category": "%command.category%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "xlsx-diff.compareActiveWith",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        },
        {
          "command": "xlsx-diff.compareTwoFiles",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@11"
        }
      ],
      "editor/title": [
        {
          "command": "xlsx-diff.compareActiveWith",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        }
      ],
      "editor/context": [
        {
          "command": "xlsx-diff.compareActiveWith",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "xlsx-diff.compareActiveWith",
          "when": "resourceScheme == file && resourceExtname == .xlsx",
          "group": "navigation@10"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "xlsx-diff.displayLanguage": {
          "type": "string",
          "enum": [
            "auto",
            "en",
            "zh-cn"
          ],
          "default": "auto",
          "markdownDescription": "%configuration.displayLanguage.description%",
          "enumDescriptions": [
            "%configuration.displayLanguage.auto%",
            "%configuration.displayLanguage.en%",
            "%configuration.displayLanguage.zhCn%"
          ]
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && tsx scripts/esbuild.mts",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "tsx scripts/esbuild.mts --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && tsx scripts/esbuild.mts --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "npm-run-all check-types:*",
    "check-types:src": "tsc --noEmit -p tsconfig.json",
    "check-types:tools": "tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint src scripts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "fastxlsx": "^1.3.1"
  }
}
